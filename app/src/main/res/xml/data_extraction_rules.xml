<?xml version="1.0" encoding="utf-8"?>
<!--
  Rules for the Data Extraction feature (Android 12+).
  See https://developer.android.com/guide/topics/data/autobackup#xml-syntax-android12
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="ebook_editor_db" />
        <exclude domain="database" path="ebook_editor_db-shm" />
        <exclude domain="database" path="ebook_editor_db-wal" />
        <exclude domain="datastore" path="." />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="ebook_editor_db" />
    </device-transfer>
</data-extraction-rules>

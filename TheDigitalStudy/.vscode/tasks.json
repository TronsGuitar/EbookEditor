{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "gradle-assemble-debug",
      "type": "shell",
      "command": ".\\gradlew.bat assembleDebug",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "android-build"
      },
      "problemMatcher": []
    },
    {
      "label": "adb-install-debug",
      "type": "shell",
      "command": "adb install -r \"${workspaceFolder}\\app\\build\\outputs\\apk\\debug\\app-debug.apk\"",
      "dependsOn": ["gradle-assemble-debug"],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "android-build"
      },
      "problemMatcher": []
    },
    {
      "label": "android-debug-setup",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\debug-android.ps1"
      ],
      "dependsOn": ["adb-install-debug"],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "android-build"
      },
      "problemMatcher": []
    }
  ]
}
